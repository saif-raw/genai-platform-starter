# Frontend Environment Variables
# Copy to .env.local and fill in your values

# Required: Groq API Key (get free at https://console.groq.com/keys)
VITE_GROQ_API_KEY=gsk_your_api_key_here

# Optional: Backend URL (for persistent metrics storage)
# Leave empty to use browser localStorage only (works on GitHub Pages)
# Examples:
#   http://localhost:3000              # Local backend
#   https://your-backend.vercel.app    # Vercel deployment
#   https://your-backend.netlify.app   # Netlify deployment
VITE_BACKEND_URL=

# Base path for GitHub Pages (auto-set by GitHub Actions)
VITE_BASE_PATH=/
