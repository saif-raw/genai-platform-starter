# Frontend Environment Variables

# API Base URL - Point to your deployed AWS backend
# Example: https://xxxx.execute-api.us-east-1.amazonaws.com/prod
VITE_API_BASE=https://your-api-gateway-url.execute-api.us-east-1.amazonaws.com/prod

# Base path for GitHub Pages (leave as / for root domain)
# Set automatically in GitHub Actions, only needed for local testing
VITE_BASE_PATH=/
